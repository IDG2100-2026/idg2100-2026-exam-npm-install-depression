@hostname = localhost
@port = 4567
@host = {{hostname}}:{{port}}
@contentType = application/json

# Run auth_tests.http first and paste tokens/IDs here
@userToken  = <Paste accessToken from auth_tests login>
@adminToken = <Paste accessToken from auth_tests adminLogin>
@userId     = <Paste user id>


### Get all matches (public, paginated)
GET http://{{host}}/api/matches?page=1&limit=10

### Filter by time control
GET http://{{host}}/api/matches?timeControl=30

### Filter by status
GET http://{{host}}/api/matches?status=waiting

### Top open matches (homepage widget)
GET http://{{host}}/api/matches/top


### Create a match (auth required)
# @name createMatch
POST http://{{host}}/api/matches
Authorization: Bearer {{userToken}}
Content-Type: {{contentType}}

{
    "category": {
        "bestOf": 3,
        "straightsAllowed": true,
        "timeControl": 30,
        "playerCount": 2,
        "buyIn": 1
    }
}

@matchId = {{createMatch.response.body.match._id}}


### Get match by ID
GET http://{{host}}/api/matches/{{matchId}}

### Get match game state (for page reload restore)
GET http://{{host}}/api/matches/{{matchId}}/state
Authorization: Bearer {{userToken}}


### Join a match
POST http://{{host}}/api/matches/{{matchId}}/players
Authorization: Bearer {{userToken}}

### Leave a match (before it starts)
DELETE http://{{host}}/api/matches/{{matchId}}/players/me
Authorization: Bearer {{userToken}}

### Finalize match with a winner (admin only)
PATCH http://{{host}}/api/matches/{{matchId}}/outcome
Authorization: Bearer {{adminToken}}
Content-Type: {{contentType}}

{
    "winnerId": "{{userId}}"
}


### Add a comment to a match
# @name createComment
POST http://{{host}}/api/matches/{{matchId}}/comments
Authorization: Bearer {{userToken}}
Content-Type: {{contentType}}

{
    "text": "This match was legendary!"
}

@commentId = {{createComment.response.body.comment._id}}

### Delete a comment (owner or admin)
DELETE http://{{host}}/api/matches/comments/{{commentId}}
Authorization: Bearer {{userToken}}


### Delete a match (admin only)
DELETE http://{{host}}/api/matches/{{matchId}}
Authorization: Bearer {{adminToken}}


### Platform activity stats (public)
GET http://{{host}}/api/stats

### Admin dashboard stats (admin only)
GET http://{{host}}/api/stats/admin
Authorization: Bearer {{adminToken}}
